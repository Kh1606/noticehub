# Frontend (npm run dev / build): no env vars required.
# Publishable Supabase URL + key live in src/lib/supabase.js.

# Scraper (python -m scrapers.run_all --supabase): REQUIRED for --supabase mode.
# Get these from: Supabase dashboard → Project Settings → API
#   - SUPABASE_URL = "Project URL"
#   - SUPABASE_SECRET_KEY = "service_role" key (NOT the publishable/anon key)
# WARNING: service_role bypasses RLS. Never commit this file.

# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SECRET_KEY=sb_secret_...
